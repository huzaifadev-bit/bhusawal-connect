---
import Switcher from '../components/Switcher.astro';
---

<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Send Parcel - Bhusawal Connect</title>
  <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline="" />
  <link href="/assets/31a15fd7aedbddede41c276e836f7170.css" rel="stylesheet" />
  <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-container": "#e5e2e1",
            "on-primary": "#ffffff",
            "on-surface-variant": "#5b4039",
            "outline": "#907067",
            "on-primary-container": "#541200",
            "surface-tint": "#b02f00",
            "secondary": "#5f5e5e",
            "inverse-primary": "#ffb5a0",
            "outline-variant": "#e4beb4",
            "on-secondary-fixed": "#1c1b1b",
            "background": "#f9f9f9",
            "error-container": "#ffdad6",
            "tertiary": "#006e1c",
            "surface-container-lowest": "#ffffff",
            "on-error": "#ffffff",
            "inverse-surface": "#2f3131",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e2e2e2",
            "secondary-fixed": "#e5e2e1",
            "tertiary-fixed": "#94f990",
            "surface-container": "#eeeeee",
            "on-surface": "#1a1c1c",
            "primary": "#b02f00",
            "primary-container": "#ff5722",
            "on-secondary-container": "#656464",
            "surface-container-low": "#f3f3f3",
            "surface-dim": "#dadada",
            "primary-fixed": "#ffdbd1",
            "on-primary-fixed-variant": "#862200",
            "error": "#ba1a1a",
            "on-error-container": "#93000a",
            "surface-container-high": "#e8e8e8",
            "surface-bright": "#f9f9f9",
            "on-secondary": "#ffffff",
            "surface": "#f9f9f9"
          },
          "fontFamily": {
            "label-sm": ["Plus Jakarta Sans"],
            "label-md": ["Plus Jakarta Sans"],
            "body-md": ["Plus Jakarta Sans"],
            "headline-md": ["Plus Jakarta Sans"],
            "headline-lg-mobile": ["Plus Jakarta Sans"]
          },
          "spacing": {
            "margin-mobile": "16px",
            "gutter": "16px"
          }
        }
      }
    }
  </script>
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9f9; min-height: 100dvh; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body class="text-on-surface bg-background pb-32">
  <!-- Top App Bar -->
  <header class="bg-surface/80 backdrop-blur-xl shadow-sm top-0 sticky z-50 flex items-center justify-between px-margin-mobile h-16 w-full">
    <div class="flex items-center gap-3">
      <a href="/home" class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150">
        <span class="material-symbols-outlined text-primary">arrow_back</span>
      </a>
      <h1 class="font-headline-lg-mobile text-headline-md text-on-surface">Send Parcel</h1>
    </div>
  </header>

  <main class="max-w-md mx-auto px-margin-mobile pt-6 space-y-6">
    <!-- Form Container -->
    <div class="bg-white rounded-2xl p-6 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] space-y-4">
      <h2 class="font-bold text-headline-md text-on-surface mb-2">Delivery Details</h2>
      
      <!-- Addresses -->
      <div class="space-y-3">
        <div>
          <label class="block text-xs font-bold text-secondary uppercase mb-1">Pickup Address</label>
          <input type="text" id="pickup-addr" class="w-full bg-surface-container-low border border-outline-variant/30 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="Enter pickup location in Bhusawal" value="Varangaon Road, Bhusawal" />
        </div>
        <div>
          <label class="block text-xs font-bold text-secondary uppercase mb-1">Drop Address</label>
          <input type="text" id="drop-addr" class="w-full bg-white border border-outline-variant/50 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all shadow-sm" placeholder="Enter recipient address" />
        </div>
      </div>

      <!-- Recipient Info -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-bold text-secondary uppercase mb-1">Receiver Name</label>
          <input type="text" id="receiver-name" class="w-full bg-white border border-outline-variant/50 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all shadow-sm" placeholder="Name" />
        </div>
        <div>
          <label class="block text-xs font-bold text-secondary uppercase mb-1">Receiver Phone</label>
          <input type="text" id="receiver-phone" class="w-full bg-white border border-outline-variant/50 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all shadow-sm" placeholder="Phone" />
        </div>
      </div>
    </div>

    <!-- Package Config -->
    <div class="bg-white rounded-2xl p-6 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] space-y-4">
      <h2 class="font-bold text-headline-md text-on-surface mb-2">Package Information</h2>

      <!-- Type Selectors -->
      <div>
        <label class="block text-xs font-bold text-secondary uppercase mb-2">Package Type</label>
        <div class="grid grid-cols-4 gap-2 text-center" id="package-types">
          <button class="p-2 border border-primary bg-primary-fixed/30 text-primary font-bold rounded-xl text-[10px] active:scale-95 transition-all">Docs</button>
          <button class="p-2 border border-outline-variant bg-white text-secondary rounded-xl text-[10px] active:scale-95 transition-all">Food</button>
          <button class="p-2 border border-outline-variant bg-white text-secondary rounded-xl text-[10px] active:scale-95 transition-all">Clothes</button>
          <button class="p-2 border border-outline-variant bg-white text-secondary rounded-xl text-[10px] active:scale-95 transition-all">Other</button>
        </div>
      </div>

      <!-- Weight Slider -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label class="text-xs font-bold text-secondary uppercase">Weight Estimation</label>
          <span class="text-sm font-bold text-primary" id="weight-label">1 kg</span>
        </div>
        <input type="range" id="weight-slider" min="1" max="15" value="1" class="w-full h-2 bg-surface-container rounded-lg appearance-none cursor-pointer accent-primary" />
        <p class="text-[10px] text-on-surface-variant mt-1">Weight changes impact base delivery fees.</p>
      </div>
    </div>

    <!-- Booking Summary Card -->
    <div class="bg-white rounded-2xl p-6 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center">
      <div>
        <p class="text-[10px] text-secondary font-bold uppercase tracking-wide">Estimated Fee</p>
        <p class="text-2xl font-bold text-primary" id="fare-label">₹50.00</p>
      </div>
      <button id="btn-book-parcel" class="bg-primary text-on-primary font-bold h-14 px-8 rounded-full flex items-center justify-center gap-2 hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary/20">
        Request Rider
        <span class="material-symbols-outlined">arrow_forward</span>
      </button>
    </div>
  </main>

  <script is:inline>
    // Handle package types selections
    const typeButtons = document.querySelectorAll('#package-types button');
    let selectedType = "Docs";

    typeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        typeButtons.forEach(b => {
          b.className = "p-2 border border-outline-variant bg-white text-secondary rounded-xl text-[10px] transition-all";
        });
        btn.className = "p-2 border border-primary bg-primary-fixed/30 text-primary font-bold rounded-xl text-[10px] transition-all";
        selectedType = btn.textContent.trim();
      });
    });

    // Handle Weight Slider & Fare logic
    const slider = document.getElementById('weight-slider');
    const weightLabel = document.getElementById('weight-label');
    const fareLabel = document.getElementById('fare-label');
    let fare = 50;

    slider.addEventListener('input', (e) => {
      const weight = parseInt(e.target.value);
      weightLabel.textContent = `${weight} kg`;
      
      // Calculate dynamic fare: base 40 + 10 per kg
      fare = 40 + (weight * 10);
      fareLabel.textContent = `₹${fare}.00`;
    });

    // Dispatch Order
    document.getElementById('btn-book-parcel').addEventListener('click', () => {
      const pickup = document.getElementById('pickup-addr').value.trim();
      const drop = document.getElementById('drop-addr').value.trim();
      const name = document.getElementById('receiver-name').value.trim();
      const phone = document.getElementById('receiver-phone').value.trim();

      if (!drop || !name || !phone) {
        alert("Please fill all drop-off and recipient fields.");
        return;
      }

      const order = {
        id: `PAR-${Math.floor(1000 + Math.random() * 9000)}`,
        items: `Parcel Courier: ${selectedType} (${weightLabel.textContent}) to ${name}`,
        total: fare,
        date: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
        status: 'Preparing'
      };

      const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
      orders.unshift(order);
      localStorage.setItem('bhusawal_orders', JSON.stringify(orders));
      localStorage.setItem('bhusawal_active_order', JSON.stringify(order));

      window.location.href = '/track_order';
    });
  </script>

  <Switcher />
</body>
</html>
