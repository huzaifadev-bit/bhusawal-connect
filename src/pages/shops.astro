---
import Switcher from '../components/Switcher.astro';
---

<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Local Shops - Bhusawal Connect</title>
  <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline="" />
  <link href="/assets/31a15fd7aedbddede41c276e836f7170.css" rel="stylesheet" />
  <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-container": "#e5e2e1",
            "on-primary": "#ffffff",
            "on-surface-variant": "#5b4039",
            "outline": "#907067",
            "on-primary-container": "#541200",
            "surface-tint": "#b02f00",
            "secondary": "#5f5e5e",
            "inverse-primary": "#ffb5a0",
            "outline-variant": "#e4beb4",
            "on-secondary-fixed": "#1c1b1b",
            "background": "#f9f9f9",
            "error-container": "#ffdad6",
            "tertiary": "#006e1c",
            "surface-container-lowest": "#ffffff",
            "on-error": "#ffffff",
            "inverse-surface": "#2f3131",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e2e2e2",
            "secondary-fixed": "#e5e2e1",
            "tertiary-fixed": "#94f990",
            "surface-container": "#eeeeee",
            "on-surface": "#1a1c1c",
            "primary": "#b02f00",
            "primary-container": "#ff5722",
            "on-secondary-container": "#656464",
            "surface-container-low": "#f3f3f3",
            "surface-dim": "#dadada",
            "primary-fixed": "#ffdbd1",
            "on-primary-fixed-variant": "#862200",
            "error": "#ba1a1a",
            "on-error-container": "#93000a",
            "surface-container-high": "#e8e8e8",
            "surface-bright": "#f9f9f9",
            "on-secondary": "#ffffff",
            "surface": "#f9f9f9"
          },
          "fontFamily": {
            "label-sm": ["Plus Jakarta Sans"],
            "label-md": ["Plus Jakarta Sans"],
            "body-md": ["Plus Jakarta Sans"],
            "headline-md": ["Plus Jakarta Sans"],
            "headline-lg-mobile": ["Plus Jakarta Sans"]
          },
          "spacing": {
            "margin-mobile": "16px",
            "gutter": "16px"
          }
        }
      }
    }
  </script>
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9f9; min-height: 100dvh; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body class="text-on-surface bg-background pb-32">
  <!-- Top App Bar -->
  <header class="bg-surface/80 backdrop-blur-xl shadow-sm top-0 sticky z-50 flex items-center justify-between px-margin-mobile h-16 w-full">
    <div class="flex items-center gap-3">
      <a href="/home" class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150">
        <span class="material-symbols-outlined text-primary">arrow_back</span>
      </a>
      <h1 class="font-headline-lg-mobile text-headline-md text-on-surface">Local Marketplace</h1>
    </div>
  </header>

  <main class="max-w-md mx-auto px-margin-mobile pt-6 space-y-6">
    <div class="flex flex-col gap-4">
      <!-- Shop 1 -->
      <a href="/grocery" class="bg-white rounded-2xl p-5 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex gap-4 hover:bg-surface-container-low transition-all">
        <div class="w-16 h-16 rounded-xl bg-primary-fixed/20 text-primary flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl">shopping_basket</span>
        </div>
        <div class="flex-1">
          <div class="flex justify-between items-start">
            <h3 class="font-bold text-label-md text-on-surface">Fresh Mart Bhusawal</h3>
            <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-0.5 rounded-full text-[9px] font-bold uppercase">Open</span>
          </div>
          <p class="text-xs text-on-surface-variant mt-1">Supermarket • Shivaji Nagar</p>
          <div class="flex items-center gap-2 mt-2 text-xs">
            <span class="material-symbols-outlined text-yellow-500 text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="font-bold">4.8</span>
          </div>
        </div>
      </a>

      <!-- Shop 2 -->
      <a href="/medicines" class="bg-white rounded-2xl p-5 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex gap-4 hover:bg-surface-container-low transition-all">
        <div class="w-16 h-16 rounded-xl bg-tertiary/10 text-tertiary flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl">medical_services</span>
        </div>
        <div class="flex-1">
          <div class="flex justify-between items-start">
            <h3 class="font-bold text-label-md text-on-surface">Modern Pharmacy</h3>
            <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-0.5 rounded-full text-[9px] font-bold uppercase">Open</span>
          </div>
          <p class="text-xs text-on-surface-variant mt-1">Medicines • Main Road, Bhusawal</p>
          <div class="flex items-center gap-2 mt-2 text-xs">
            <span class="material-symbols-outlined text-yellow-500 text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="font-bold">4.6</span>
          </div>
        </div>
      </a>

      <!-- Shop 3 -->
      <a href="/food" class="bg-white rounded-2xl p-5 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex gap-4 hover:bg-surface-container-low transition-all">
        <div class="w-16 h-16 rounded-xl bg-orange-100 text-primary-container flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">restaurant</span>
        </div>
        <div class="flex-1">
          <div class="flex justify-between items-start">
            <h3 class="font-bold text-label-md text-on-surface">Spice Village</h3>
            <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-0.5 rounded-full text-[9px] font-bold uppercase">Open</span>
          </div>
          <p class="text-xs text-on-surface-variant mt-1">North Indian • Varangaon Road</p>
          <div class="flex items-center gap-2 mt-2 text-xs">
            <span class="material-symbols-outlined text-yellow-500 text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="font-bold">4.2</span>
          </div>
        </div>
      </a>

      <!-- Shop 4 -->
      <a href="/grocery" class="bg-white rounded-2xl p-5 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex gap-4 hover:bg-surface-container-low transition-all">
        <div class="w-16 h-16 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center">
          <span class="material-symbols-outlined text-3xl">storefront</span>
        </div>
        <div class="flex-1">
          <div class="flex justify-between items-start">
            <h3 class="font-bold text-label-md text-on-surface">Khandesh Dairy</h3>
            <span class="bg-tertiary-fixed text-on-tertiary-fixed px-2 py-0.5 rounded-full text-[9px] font-bold uppercase">Open</span>
          </div>
          <p class="text-xs text-on-surface-variant mt-1">Dairy & Staples • City Market</p>
          <div class="flex items-center gap-2 mt-2 text-xs">
            <span class="material-symbols-outlined text-yellow-500 text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="font-bold">4.7</span>
          </div>
        </div>
      </a>
    </div>
  </main>

  <!-- Bottom Navigation -->
  <nav class="fixed bottom-0 w-full flex justify-around items-center h-20 pb-safe px-4 bg-surface/80 backdrop-blur-xl z-50 border-t border-outline-variant/30 shadow-[0_-4px_12px_rgba(0,0,0,0.04)]">
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/home">
      <span class="material-symbols-outlined">home</span>
      <span class="font-label-sm text-label-sm">Home</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/orders">
      <span class="material-symbols-outlined">receipt_long</span>
      <span class="font-label-sm text-label-sm">Orders</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/grocery">
      <span class="material-symbols-outlined">search</span>
      <span class="font-label-sm text-label-sm">Search</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/profile">
      <span class="material-symbols-outlined">person</span>
      <span class="font-label-sm text-label-sm">Account</span>
    </a>
  </nav>

  <Switcher />
</body>
</html>
