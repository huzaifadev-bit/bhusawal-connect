---
import Switcher from '../components/Switcher.astro';
---

<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Track Order - Bhusawal Connect</title>
  <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline="" />
  <link href="/assets/31a15fd7aedbddede41c276e836f7170.css" rel="stylesheet" />
  <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-container": "#e5e2e1",
            "on-primary": "#ffffff",
            "on-surface-variant": "#5b4039",
            "outline": "#907067",
            "on-primary-container": "#541200",
            "surface-tint": "#b02f00",
            "secondary": "#5f5e5e",
            "inverse-primary": "#ffb5a0",
            "outline-variant": "#e4beb4",
            "on-secondary-fixed": "#1c1b1b",
            "background": "#f9f9f9",
            "error-container": "#ffdad6",
            "tertiary": "#006e1c",
            "surface-container-lowest": "#ffffff",
            "on-error": "#ffffff",
            "inverse-surface": "#2f3131",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e2e2e2",
            "secondary-fixed": "#e5e2e1",
            "tertiary-fixed": "#94f990",
            "surface-container": "#eeeeee",
            "on-surface": "#1a1c1c",
            "primary": "#b02f00",
            "primary-container": "#ff5722",
            "on-secondary-container": "#656464",
            "surface-container-low": "#f3f3f3",
            "surface-dim": "#dadada",
            "primary-fixed": "#ffdbd1",
            "on-primary-fixed-variant": "#862200",
            "error": "#ba1a1a",
            "on-error-container": "#93000a",
            "surface-container-high": "#e8e8e8",
            "surface-bright": "#f9f9f9",
            "on-secondary": "#ffffff",
            "surface": "#f9f9f9"
          },
          "fontFamily": {
            "label-sm": ["Plus Jakarta Sans"],
            "label-md": ["Plus Jakarta Sans"],
            "headline-xl": ["Plus Jakarta Sans"],
            "headline-lg": ["Plus Jakarta Sans"],
            "body-lg": ["Plus Jakarta Sans"],
            "headline-md": ["Plus Jakarta Sans"],
            "headline-lg-mobile": ["Plus Jakarta Sans"],
            "body-md": ["Plus Jakarta Sans"]
          },
          "fontSize": {
            "label-sm": ["12px", {"lineHeight": "16px", "fontWeight": "500"}],
            "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "600"}],
            "headline-xl": ["40px", {"lineHeight": "48px", "letterSpacing": "-0.02em", "fontWeight": "800"}],
            "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "700"}],
            "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
            "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "700"}],
            "headline-lg-mobile": ["28px", {"lineHeight": "36px", "fontWeight": "700"}],
            "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}]
          },
          "spacing": {
            "margin-desktop": "64px",
            "unit": "4px",
            "gutter": "16px",
            "container-max": "1280px",
            "margin-mobile": "16px"
          }
        }
      }
    }
  </script>
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9f9; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .pulse-orange {
      animation: pulse-ring 2s cubic-bezier(0.215, 0.610, 0.355, 1) infinite;
    }
    @keyframes pulse-ring {
      0% { box-shadow: 0 0 0 0 rgba(176, 47, 0, 0.4); }
      70% { box-shadow: 0 0 0 12px rgba(176, 47, 0, 0); }
      100% { box-shadow: 0 0 0 0 rgba(176, 47, 0, 0); }
    }
    .step-line::after {
      content: '';
      position: absolute;
      left: 19px;
      top: 36px;
      bottom: -16px;
      width: 2px;
      background: #e4beb4;
    }
    .step-line-active::after {
      background: #b02f00;
    }
    .step-line:last-child::after { display: none; }
  </style>
</head>
<body class="text-on-surface bg-background min-h-screen">
  <!-- Top App Bar -->
  <header class="bg-surface/80 backdrop-blur-xl shadow-sm docked full-width top-0 sticky z-50 flex items-center justify-between px-margin-mobile h-16 w-full">
    <div class="flex items-center gap-3">
      <a href="/orders" class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150 ease-in-out">
        <span class="material-symbols-outlined text-primary">arrow_back</span>
      </a>
      <h1 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">Track Order</h1>
    </div>
  </header>

  <main class="max-w-md mx-auto">
    <!-- Map Background / Viewport -->
    <div class="h-64 w-full bg-surface-container relative overflow-hidden">
      <!-- Sat Image from Book Ride page, cropped for map detail -->
      <img class="w-full h-full object-cover grayscale-[10%]" src="/assets/3c1d7d235563048e76ffef4606d7a7af.jpg" alt="Map View" />
      
      <!-- Pulsing Pin representing current delivery rider -->
      <div class="absolute top-[40%] left-[35%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center pulse-orange">
          <div class="w-6 h-6 rounded-full bg-primary flex items-center justify-center text-on-primary">
            <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">local_shipping</span>
          </div>
        </div>
      </div>
      
      <!-- Delivery Destination Pin -->
      <div class="absolute top-[60%] left-[65%] -translate-x-1/2 -translate-y-1/2 flex flex-col items-center">
        <div class="w-8 h-8 rounded-full bg-tertiary flex items-center justify-center text-on-tertiary">
          <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">home</span>
        </div>
      </div>
    </div>

    <!-- Active Status Card -->
    <div class="bg-white rounded-t-[32px] -mt-6 relative z-10 px-margin-mobile pt-6 pb-12 border-t border-outline-variant/10 shadow-[0_-8px_24px_rgba(0,0,0,0.04)]">
      <!-- Active Order Info -->
      <div class="flex justify-between items-start border-b border-outline-variant/10 pb-4 mb-6">
        <div>
          <h2 class="font-bold text-headline-md text-on-surface" id="tracking-store">Bhusawal Delivery</h2>
          <p class="text-xs text-on-surface-variant" id="tracking-id">Order #BHU-8921</p>
        </div>
        <div class="text-right">
          <p class="text-[10px] text-secondary font-bold uppercase tracking-wide">Estimated Delivery</p>
          <p class="text-lg font-bold text-primary" id="tracking-time">15 - 20 Mins</p>
        </div>
      </div>

      <!-- Live Stepper Tracker -->
      <div class="space-y-6">
        <!-- Step 1 -->
        <div class="flex gap-4 relative step-line step-line-active">
          <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center z-10 font-bold">
            <span class="material-symbols-outlined text-lg">check</span>
          </div>
          <div>
            <h4 class="font-bold text-sm text-on-surface">Order Confirmed</h4>
            <p class="text-xs text-on-surface-variant">Order placed and approved by store.</p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flex gap-4 relative step-line step-line-active">
          <div class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center z-10 font-bold pulse-orange">
            <span class="material-symbols-outlined text-lg">restaurant_menu</span>
          </div>
          <div>
            <h4 class="font-bold text-sm text-primary" id="step-active-text">Preparing Order</h4>
            <p class="text-xs text-on-surface-variant" id="step-active-desc">The merchant is preparing your package.</p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flex gap-4 relative step-line">
          <div class="w-10 h-10 rounded-full bg-outline-variant/30 text-on-surface-variant/40 flex items-center justify-center z-10 font-bold">
            <span class="material-symbols-outlined text-lg">local_shipping</span>
          </div>
          <div>
            <h4 class="font-bold text-sm text-on-surface-variant/60">Out for Delivery</h4>
            <p class="text-xs text-on-surface-variant/50">Delivery partner will pick up soon.</p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="flex gap-4 relative">
          <div class="w-10 h-10 rounded-full bg-outline-variant/30 text-on-surface-variant/40 flex items-center justify-center z-10 font-bold">
            <span class="material-symbols-outlined text-lg">done_all</span>
          </div>
          <div>
            <h4 class="font-bold text-sm text-on-surface-variant/60">Delivered</h4>
            <p class="text-xs text-on-surface-variant/50">Enjoy your order!</p>
          </div>
        </div>
      </div>

      <!-- Action Button -->
      <div class="mt-10 flex flex-col gap-3">
        <a href="/home" class="w-full h-14 bg-primary text-on-primary font-bold rounded-full flex items-center justify-center gap-2 hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-primary/20">
          Back to Home
        </a>
        <a href="/orders" class="w-full h-14 border border-outline text-on-surface font-bold rounded-full flex items-center justify-center hover:bg-surface-container-low transition-all">
          View All Orders
        </a>
      </div>
    </div>
  </main>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const activeOrder = JSON.parse(localStorage.getItem('bhusawal_active_order'));
      if (activeOrder) {
        document.getElementById('tracking-id').textContent = `Order #${activeOrder.id}`;
        document.getElementById('tracking-store').textContent = activeOrder.items.startsWith("Prescription") ? "Pharmacy Fulfilled" : "Grocery Store Delivery";
        
        if (activeOrder.status === 'Verifying') {
          document.getElementById('step-active-text').textContent = "Verifying Prescription";
          document.getElementById('step-active-desc').textContent = "Pharmacist is verifying your uploaded receipt.";
          document.getElementById('tracking-time').textContent = "Verification...";
        } else {
          document.getElementById('step-active-text').textContent = "Preparing Order";
          document.getElementById('step-active-desc').textContent = "Store partner is packing your items.";
          document.getElementById('tracking-time').textContent = "10 - 15 Mins";
        }
      }
    });
  </script>

  <Switcher />
</body>
</html>