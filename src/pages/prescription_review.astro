<!-- Floating Action Button - Supressed as per Guidelines for Dashboard sub-tasks if needed, but contextually useful for "Quick Help" -->
<script>
        const toggle = document.getElementById('status-toggle');
        const statusText = document.getElementById('status-text');
        const statusIndicator = document.getElementById('status-indicator');

        toggle.addEventListener('change', function() {
            if (this.checked) {
                statusText.innerText = 'Online';
                statusIndicator.classList.remove('bg-error');
                statusIndicator.classList.add('bg-tertiary-container');
                statusIndicator.classList.add('status-pulse');
            } else {
                statusText.innerText = 'Offline';
                statusIndicator.classList.remove('bg-tertiary-container');
                statusIndicator.classList.add('bg-error');
                statusIndicator.classList.remove('status-pulse');
            }
        });

        // Synced Rider accept trip / delivery simulation
        document.querySelectorAll('button').forEach(btn => {
            if(btn.innerText.trim() === 'Accept Trip') {
                btn.addEventListener('click', () => {
                    btn.innerText = 'Trip Accepted!';
                    btn.classList.replace('bg-primary-container', 'bg-tertiary');
                    
                    // Update active order in localStorage to 'Out for Delivery'
                    const activeOrder = JSON.parse(localStorage.getItem('bhusawal_active_order') || '{}');
                    if (activeOrder.id) {
                        activeOrder.status = 'Out for Delivery';
                        localStorage.setItem('bhusawal_active_order', JSON.stringify(activeOrder));
                        
                        const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
                        const updated = orders.map(o => {
                            if (o.id === activeOrder.id) o.status = 'Out for Delivery';
                            return o;
                        });
                        localStorage.setItem('bhusawal_orders', JSON.stringify(updated));
                    }
                    
                    setTimeout(() => {
                        btn.innerText = 'Complete Delivery';
                        btn.onclick = () => {
                            btn.innerText = 'Delivered!';
                            btn.classList.replace('bg-tertiary', 'bg-secondary');
                            
                            // Set to Delivered
                            if (activeOrder.id) {
                                activeOrder.status = 'Delivered';
                                localStorage.setItem('bhusawal_active_order', JSON.stringify(activeOrder));
                                
                                const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
                                const updated = orders.map(o => {
                                    if (o.id === activeOrder.id) o.status = 'Delivered';
                                    return o;
                                });
                                localStorage.setItem('bhusawal_orders', JSON.stringify(updated));
                            }
                            alert('Order delivered successfully!');
                            window.location.reload();
                        };
                    }, 1500);
                });
            }
        });
    </script>
    <Switcher />
