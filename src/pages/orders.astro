---
import Switcher from '../components/Switcher.astro';
---

<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Your Orders - Bhusawal Connect</title>
  <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline="" />
  <link href="/assets/31a15fd7aedbddede41c276e836f7170.css" rel="stylesheet" />
  <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-container": "#e5e2e1",
            "on-primary": "#ffffff",
            "on-surface-variant": "#5b4039",
            "outline": "#907067",
            "on-primary-container": "#541200",
            "surface-tint": "#b02f00",
            "secondary": "#5f5e5e",
            "inverse-primary": "#ffb5a0",
            "outline-variant": "#e4beb4",
            "on-secondary-fixed": "#1c1b1b",
            "background": "#f9f9f9",
            "error-container": "#ffdad6",
            "tertiary": "#006e1c",
            "surface-container-lowest": "#ffffff",
            "on-error": "#ffffff",
            "inverse-surface": "#2f3131",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e2e2e2",
            "secondary-fixed": "#e5e2e1",
            "tertiary-fixed": "#94f990",
            "surface-container": "#eeeeee",
            "on-surface": "#1a1c1c",
            "primary": "#b02f00",
            "primary-container": "#ff5722",
            "on-secondary-container": "#656464",
            "surface-container-low": "#f3f3f3",
            "surface-dim": "#dadada",
            "primary-fixed": "#ffdbd1",
            "on-primary-fixed-variant": "#862200",
            "error": "#ba1a1a",
            "on-error-container": "#93000a",
            "surface-container-high": "#e8e8e8",
            "surface-bright": "#f9f9f9",
            "on-secondary": "#ffffff",
            "surface": "#f9f9f9"
          },
          "fontFamily": {
            "label-sm": ["Plus Jakarta Sans"],
            "label-md": ["Plus Jakarta Sans"],
            "headline-xl": ["Plus Jakarta Sans"],
            "headline-lg": ["Plus Jakarta Sans"],
            "body-lg": ["Plus Jakarta Sans"],
            "headline-md": ["Plus Jakarta Sans"],
            "headline-lg-mobile": ["Plus Jakarta Sans"],
            "body-md": ["Plus Jakarta Sans"]
          },
          "fontSize": {
            "label-sm": ["12px", {"lineHeight": "16px", "fontWeight": "500"}],
            "label-md": ["14px", {"lineHeight": "20px", "letterSpacing": "0.01em", "fontWeight": "600"}],
            "headline-xl": ["40px", {"lineHeight": "48px", "letterSpacing": "-0.02em", "fontWeight": "800"}],
            "headline-lg": ["32px", {"lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "700"}],
            "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
            "headline-md": ["24px", {"lineHeight": "32px", "fontWeight": "700"}],
            "headline-lg-mobile": ["28px", {"lineHeight": "36px", "fontWeight": "700"}],
            "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}]
          },
          "spacing": {
            "margin-desktop": "64px",
            "unit": "4px",
            "gutter": "16px",
            "container-max": "1280px",
            "margin-mobile": "16px"
          }
        }
      }
    }
  </script>
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9f9; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .active-icon {
      font-variation-settings: 'FILL' 1;
    }
  </style>
</head>
<body class="text-on-surface bg-background min-h-screen">
  <!-- Top App Bar -->
  <header class="bg-surface/80 backdrop-blur-xl shadow-sm docked full-width top-0 sticky z-50 flex items-center justify-between px-margin-mobile h-16 w-full">
    <div class="flex items-center gap-3">
      <a href="/home" class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150 ease-in-out">
        <span class="material-symbols-outlined text-primary">arrow_back</span>
      </a>
      <h1 class="font-headline-lg-mobile text-headline-lg-mobile text-on-surface">Your Orders</h1>
    </div>
    <div class="flex items-center gap-2">
      <button class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150">
        <span class="material-symbols-outlined text-primary">notifications</span>
      </button>
    </div>
  </header>

  <main class="max-w-md mx-auto px-margin-mobile pt-6 pb-32">
    <!-- Active Orders Section -->
    <section class="mb-8">
      <h2 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-4">Active Orders</h2>
      <div id="active-orders-list" class="space-y-4">
        <!-- Dynmically rendered or static fallback -->
      </div>
    </section>

    <!-- Past Orders Section -->
    <section>
      <h2 class="font-label-md text-label-md text-secondary uppercase tracking-widest mb-4">Order History</h2>
      <div id="past-orders-list" class="space-y-4">
        <!-- Mock Order 1 -->
        <div class="bg-white p-5 rounded-2xl border border-outline-variant/20 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex flex-col gap-3">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-bold text-label-md text-on-surface">Spice Village</h3>
              <p class="text-xs text-on-surface-variant">Order #BHU-3829 • 04 July, 08:30 PM</p>
            </div>
            <span class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-[10px] font-bold uppercase">Completed</span>
          </div>
          <div class="text-sm text-on-surface-variant border-t border-b border-outline-variant/10 py-2">
            1x Butter Chicken, 2x Butter Naan
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="font-bold">Total Paid: ₹420.00</span>
            <a href="/track_order" class="text-primary hover:underline text-xs font-bold">View Details</a>
          </div>
        </div>

        <!-- Mock Order 2 -->
        <div class="bg-white p-5 rounded-2xl border border-outline-variant/20 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex flex-col gap-3">
          <div class="flex justify-between items-start">
            <div>
              <h3 class="font-bold text-label-md text-on-surface">Fresh Mart Bhusawal</h3>
              <p class="text-xs text-on-surface-variant">Order #BHU-1024 • 01 July, 11:20 AM</p>
            </div>
            <span class="bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full text-[10px] font-bold uppercase">Completed</span>
          </div>
          <div class="text-sm text-on-surface-variant border-t border-b border-outline-variant/10 py-2">
            1x Amul Full Cream Milk, 1x Multi-grain Bread
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="font-bold">Total Paid: ₹78.00</span>
            <a href="/track_order" class="text-primary hover:underline text-xs font-bold">View Details</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- Bottom Navigation (Mobile) -->
  <nav class="fixed bottom-0 w-full flex justify-around items-center h-20 pb-safe px-4 bg-surface/80 dark:bg-inverse-surface/80 backdrop-blur-xl shadow-[0_-4px_12px_rgba(0,0,0,0.04)] border-t border-outline-variant/30 z-50">
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all" href="/home">
      <span class="material-symbols-outlined">home</span>
      <span class="font-label-sm text-label-sm">Home</span>
    </a>
    <a class="flex flex-col items-center justify-center text-primary bg-primary-fixed/30 rounded-full px-4 py-1 active:scale-90 duration-200" href="/orders">
      <span class="material-symbols-outlined active-icon">receipt_long</span>
      <span class="font-label-sm text-label-sm">Orders</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all" href="/medicine_search">
      <span class="material-symbols-outlined">search</span>
      <span class="font-label-sm text-label-sm">Search</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all" href="/profile">
      <span class="material-symbols-outlined">person</span>
      <span class="font-label-sm text-label-sm">Account</span>
    </a>
  </nav>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const activeList = document.getElementById('active-orders-list');
      const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');

      if (orders.length === 0) {
        activeList.innerHTML = `
          <div class="p-6 text-center text-on-surface-variant bg-white border border-outline-variant/10 rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.02)]">
            <span class="material-symbols-outlined text-4xl text-outline-variant/60 mb-2">inbox</span>
            <p class="text-sm">No active orders right now.</p>
            <a href="/medicine_search" class="mt-3 inline-block bg-primary text-on-primary text-xs px-4 py-2 rounded-full font-bold hover:brightness-110">Go Shop</a>
          </div>
        `;
      } else {
        activeList.innerHTML = orders.map(order => `
          <div class="bg-white p-5 rounded-2xl border border-primary/20 shadow-[0_4px_16px_rgba(176,47,0,0.05)] flex flex-col gap-3">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-bold text-label-md text-on-surface">Store Delivery</h3>
                <p class="text-xs text-on-surface-variant">Order #${order.id} • Today, ${order.date}</p>
              </div>
              <span class="bg-primary-fixed text-on-primary-fixed px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider animate-pulse">${order.status}</span>
            </div>
            <div class="text-sm text-on-surface-variant border-t border-b border-outline-variant/10 py-2">
              ${order.items}
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="font-bold text-primary">Amount: ₹${order.total}</span>
              <a href="/track_order" class="bg-primary text-on-primary text-xs px-4 py-2 rounded-xl font-bold hover:brightness-110 active:scale-95 transition-all">Track Order</a>
            </div>
          </div>
        `).join('');
      }
    });
  </script>

  <Switcher />
</body>
</html>