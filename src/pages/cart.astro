</div>
</div>
</aside>
<!-- Main Content Canvas -->
<main class="flex-1 ml-0 md:ml-64 h-screen overflow-y-auto custom-scrollbar flex flex-col">
<!-- TopAppBar -->
<header class="bg-surface/80 backdrop-blur-xl shadow-sm h-16 sticky top-0 z-50 flex items-center justify-between px-margin-mobile md:px-10 w-full shrink-0">
<div class="flex items-center space-x-4">
<button class="md:hidden text-primary">
<span class="material-symbols-outlined" data-icon="menu">menu</span>
</button>
<div class="flex items-center text-primary">
<span class="material-symbols-outlined mr-2" data-icon="location_on">location_on</span>
<span class="font-label-md text-label-md">Bhusawal, MH</span>
</div>
</div>
<div class="flex items-center space-x-4">
<div class="relative hidden sm:block">
<span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-secondary" data-icon="search">search</span>
<input class="bg-surface-container border-none rounded-full pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary w-64" placeholder="Search data..." type="text" />
</div>
<button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-primary active:scale-95 duration-150">
<span class="material-symbols-outlined" data-icon="notifications">notifications</span>
