<span class="material-symbols-outlined mr-3" data-icon="settings">settings</span>
<span class="font-body-md text-body-md">Settings</span>
</a>
</nav>
<div class="px-6 mt-8">
<div class="bg-surface-container-high rounded-xl p-4 flex items-center space-x-3">
<div class="w-10 h-10 rounded-full bg-primary-fixed-dim flex items-center justify-center text-on-primary-fixed-variant font-bold">
