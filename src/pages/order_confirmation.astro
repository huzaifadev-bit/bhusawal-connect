<script>
        // Micro-interaction for buttons
        document.querySelectorAll('button').forEach(button => {
            button.addEventListener('mousedown', () => {
                button.classList.add('scale-95');
            });
            button.addEventListener('mouseup', () => {
                button.classList.remove('scale-95');
            });
            button.addEventListener('mouseleave', () => {
                button.classList.remove('scale-95');
            });
        });

        // Tab Switching Logic (Simulated)
        const tabs = document.querySelectorAll('button[class*="pb-4"]');
        tabs.forEach(tab => {
            tab.addEventListener('click', (e) => {
                tabs.forEach(t => {
                    t.classList.remove('text-primary');
                    t.classList.add('text-on-surface-variant');
                    const indicator = t.querySelector('.active-tab-indicator');
                    if(indicator) indicator.remove();
                });
                tab.classList.add('text-primary');
                tab.classList.remove('text-on-surface-variant');
                const indicator = document.createElement('div');
                indicator.className = 'active-tab-indicator';
                tab.appendChild(indicator);
            });
        });

        // Dynamic accept/ready order logic synced with localStorage
        window.updateOrderStatus = (orderId, newStatus) => {
            const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
            const updated = orders.map(o => {
                if (o.id === orderId) {
                    o.status = newStatus;
                }
                return o;
            });
            localStorage.setItem('bhusawal_orders', JSON.stringify(updated));

            const activeOrder = JSON.parse(localStorage.getItem('bhusawal_active_order') || '{}');
            if (activeOrder.id === orderId) {
                activeOrder.status = newStatus;
                localStorage.setItem('bhusawal_active_order', JSON.stringify(activeOrder));
            }
            alert(`Order #${orderId} status updated to: ${newStatus}`);
            window.location.reload();
        };

        // Attach to Accept/Ready buttons in static markup
        document.querySelectorAll('button').forEach(btn => {
            const card = btn.closest('.glass-card') || btn.closest('.bg-surface-container-low');
            if (!card) return;
            const orderTextElement = card.querySelector('p.font-label-sm') || card.querySelector('p.text-secondary');
            if (!orderTextElement) return;

            const orderText = orderTextElement.textContent.trim();
            const matches = orderText.match(/#([A-Z0-9-]+)/);
            if (!matches) return;
            const orderId = matches[1];

            if (btn.textContent.trim() === 'Accept Order') {
                btn.addEventListener('click', () => {
                    window.updateOrderStatus(orderId, 'Preparing');
                });
            } else if (btn.textContent.trim() === 'Ready') {
                btn.addEventListener('click', () => {
                    window.updateOrderStatus(orderId, 'Ready for Pickup');
                });
            }
        });

        // Prepend dynamic orders from localStorage if any
        document.addEventListener('DOMContentLoaded', () => {
            const ordersGrid = document.querySelector('.grid.grid-cols-1');
            if (!ordersGrid) return;
            
            const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
            orders.forEach(order => {
                if (order.status === 'Preparing' || order.status === 'Verifying') {
                    const card = document.createElement('div');
                    card.className = 'glass-card rounded-2xl p-6 shadow-[0_4px_12px_rgba(0,0,0,0.04)] border border-primary/10 relative overflow-hidden flex flex-col h-full animate-in fade-in duration-300';
                    card.innerHTML = `
                        <div class="absolute top-0 right-0 p-3">
                            <span class="bg-primary-fixed text-on-primary-fixed px-3 py-1 rounded-full font-label-sm uppercase tracking-wider">${order.status}</span>
                        </div>
                        <div class="flex items-center gap-4 mb-4">
                            <div class="w-12 h-12 rounded-full overflow-hidden bg-primary-fixed/20 flex items-center justify-center text-primary font-bold">
                                ${order.id.slice(0, 2)}
                            </div>
                            <div>
                                <h3 class="font-label-md text-on-surface">Shivaji Nagar Customer</h3>
                                <p class="font-label-sm text-on-surface-variant">Order #${order.id}</p>
                            </div>
                        </div>
                        <div class="flex-1 mb-4">
                            <div class="space-y-2 mb-6">
                                <div class="flex justify-between items-center">
                                    <span class="font-body-md text-on-surface-variant">${order.items}</span>
                                    <span class="font-label-md text-on-surface">₹${order.total}</span>
                                </div>
                                <div class="flex justify-between items-center pt-2 border-t border-outline-variant/30">
                                    <span class="font-label-md text-on-surface">Total Amount</span>
                                    <span class="font-headline-md text-primary">₹${order.total}.00</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex gap-3">
                            <button class="flex-1 py-4 bg-primary text-on-primary rounded-xl font-label-md hover:brightness-110 active:scale-[0.98] transition-all shadow-lg shadow-primary/20" onclick="window.updateOrderStatus('${order.id}', 'Preparing')">Accept Order</button>
                            <button class="px-4 py-4 bg-surface-container rounded-xl text-on-surface-variant hover:bg-error-container hover:text-on-error-container transition-all">
                                <span class="material-symbols-outlined">close</span>
                            </button>
                        </div>
                    `;
                    ordersGrid.insertBefore(card, ordersGrid.firstChild);
                }
            });
        });
    </script>
    <Switcher />
</body></html>