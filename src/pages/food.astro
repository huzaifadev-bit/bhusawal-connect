---
import Switcher from '../components/Switcher.astro';
---

<html class="light" lang="en">
<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0" name="viewport" />
  <title>Spice Village - Food Menu</title>
  <script src="/assets/03ba5d9f9e95fc3599acebcbe7e5fb9a.js" is:inline="" />
  <link href="/assets/31a15fd7aedbddede41c276e836f7170.css" rel="stylesheet" />
  <link href="/assets/a39f5c6fcbb87b419667ec984d2e579a.css" rel="stylesheet" />
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "secondary-container": "#e5e2e1",
            "on-primary": "#ffffff",
            "on-surface-variant": "#5b4039",
            "outline": "#907067",
            "on-primary-container": "#541200",
            "surface-tint": "#b02f00",
            "secondary": "#5f5e5e",
            "inverse-primary": "#ffb5a0",
            "outline-variant": "#e4beb4",
            "on-secondary-fixed": "#1c1b1b",
            "background": "#f9f9f9",
            "error-container": "#ffdad6",
            "tertiary": "#006e1c",
            "surface-container-lowest": "#ffffff",
            "on-error": "#ffffff",
            "inverse-surface": "#2f3131",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e2e2e2",
            "secondary-fixed": "#e5e2e1",
            "tertiary-fixed": "#94f990",
            "surface-container": "#eeeeee",
            "on-surface": "#1a1c1c",
            "primary": "#b02f00",
            "primary-container": "#ff5722",
            "on-secondary-container": "#656464",
            "surface-container-low": "#f3f3f3",
            "surface-dim": "#dadada",
            "primary-fixed": "#ffdbd1",
            "on-primary-fixed-variant": "#862200",
            "error": "#ba1a1a",
            "on-error-container": "#93000a",
            "surface-container-high": "#e8e8e8",
            "surface-bright": "#f9f9f9",
            "on-secondary": "#ffffff",
            "surface": "#f9f9f9"
          },
          "fontFamily": {
            "label-sm": ["Plus Jakarta Sans"],
            "label-md": ["Plus Jakarta Sans"],
            "body-md": ["Plus Jakarta Sans"],
            "headline-md": ["Plus Jakarta Sans"],
            "headline-lg-mobile": ["Plus Jakarta Sans"]
          },
          "spacing": {
            "margin-mobile": "16px",
            "gutter": "16px"
          }
        }
      }
    }
  </script>
  
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f9f9f9; min-height: 100dvh; }
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
  </style>
</head>
<body class="text-on-surface bg-background pb-32">
  <!-- Top App Bar -->
  <header class="bg-surface/80 backdrop-blur-xl shadow-sm top-0 sticky z-50 flex items-center justify-between px-margin-mobile h-16 w-full">
    <div class="flex items-center gap-3">
      <a href="/home" class="p-2 hover:bg-surface-container-high rounded-full transition-colors active:scale-95 duration-150">
        <span class="material-symbols-outlined text-primary">arrow_back</span>
      </a>
      <div>
        <h1 class="font-headline-lg-mobile text-headline-md text-on-surface">Spice Village</h1>
        <p class="text-[10px] text-on-surface-variant font-bold">North Indian • Varangaon Road</p>
      </div>
    </div>
  </header>

  <main class="max-w-md mx-auto px-margin-mobile pt-6 space-y-6">
    <!-- Restaurant Rating & Details Banner -->
    <div class="bg-white rounded-2xl p-5 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-yellow-500" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="font-bold text-label-md">4.2 (100+ ratings)</span>
      </div>
      <div class="h-4 w-px bg-outline-variant/30" />
      <div>
        <span class="text-xs text-on-surface-variant">25-30 Mins Delivery</span>
      </div>
    </div>

    <!-- Veg / Non-Veg Toggle -->
    <div class="flex gap-3" id="veg-filters">
      <button id="btn-all" class="px-4 py-2 rounded-full border border-primary bg-primary-fixed/30 text-primary font-bold text-xs active:scale-95 transition-all">All</button>
      <button id="btn-veg" class="px-4 py-2 rounded-full border border-outline-variant bg-white text-tertiary font-bold text-xs flex items-center gap-1 active:scale-95 transition-all">
        <span class="w-3 h-3 rounded-sm border border-tertiary flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-tertiary"></span></span>
        Veg Only
      </button>
      <button id="btn-nonveg" class="px-4 py-2 rounded-full border border-outline-variant bg-white text-error font-bold text-xs flex items-center gap-1 active:scale-95 transition-all">
        <span class="w-3 h-3 rounded-sm border border-error flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-error"></span></span>
        Non-Veg
      </button>
    </div>

    <!-- Menu Items List -->
    <section class="space-y-4">
      <h2 class="font-bold text-headline-md text-on-surface">Popular Menu</h2>
      <div class="space-y-4" id="menu-container">
        <!-- Item 1 -->
        <div class="bg-white rounded-2xl p-4 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center food-item" data-type="nonveg">
          <div class="flex-1 pr-4">
            <span class="w-4 h-4 rounded-sm border border-error flex items-center justify-center mb-1"><span class="w-2 h-2 rounded-full bg-error"></span></span>
            <h3 class="font-bold text-label-md text-on-surface">Butter Chicken</h3>
            <p class="text-xs text-on-surface-variant mt-1">Rich creamy gravy with tender tandoori chicken pieces.</p>
            <p class="font-bold text-on-surface mt-2">₹280</p>
          </div>
          <button class="bg-primary text-on-primary px-6 py-2 rounded-xl text-xs font-bold hover:brightness-110 active:scale-90 transition-all self-center">Add</button>
        </div>

        <!-- Item 2 -->
        <div class="bg-white rounded-2xl p-4 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center food-item" data-type="veg">
          <div class="flex-1 pr-4">
            <span class="w-4 h-4 rounded-sm border border-tertiary flex items-center justify-center mb-1"><span class="w-2 h-2 rounded-full bg-tertiary"></span></span>
            <h3 class="font-bold text-label-md text-on-surface">Paneer Butter Masala</h3>
            <p class="text-xs text-on-surface-variant mt-1">Soft paneer cubes cooked in a spiced rich tomato butter sauce.</p>
            <p class="font-bold text-on-surface mt-2">₹220</p>
          </div>
          <button class="bg-primary text-on-primary px-6 py-2 rounded-xl text-xs font-bold hover:brightness-110 active:scale-90 transition-all self-center">Add</button>
        </div>

        <!-- Item 3 -->
        <div class="bg-white rounded-2xl p-4 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center food-item" data-type="nonveg">
          <div class="flex-1 pr-4">
            <span class="w-4 h-4 rounded-sm border border-error flex items-center justify-center mb-1"><span class="w-2 h-2 rounded-full bg-error"></span></span>
            <h3 class="font-bold text-label-md text-on-surface">Chicken Tikka</h3>
            <p class="text-xs text-on-surface-variant mt-1">6 pieces of juicy clay oven charcoal grilled chicken.</p>
            <p class="font-bold text-on-surface mt-2">₹220</p>
          </div>
          <button class="bg-primary text-on-primary px-6 py-2 rounded-xl text-xs font-bold hover:brightness-110 active:scale-90 transition-all self-center">Add</button>
        </div>

        <!-- Item 4 -->
        <div class="bg-white rounded-2xl p-4 border border-outline-variant/10 shadow-[0_4px_12px_rgba(0,0,0,0.02)] flex justify-between items-center food-item" data-type="veg">
          <div class="flex-1 pr-4">
            <span class="w-4 h-4 rounded-sm border border-tertiary flex items-center justify-center mb-1"><span class="w-2 h-2 rounded-full bg-tertiary"></span></span>
            <h3 class="font-bold text-label-md text-on-surface">Garlic Naan</h3>
            <p class="text-xs text-on-surface-variant mt-1">Tandoori flatbread garnished with minced garlic and butter.</p>
            <p class="font-bold text-on-surface mt-2">₹45</p>
          </div>
          <button class="bg-primary text-on-primary px-6 py-2 rounded-xl text-xs font-bold hover:brightness-110 active:scale-90 transition-all self-center">Add</button>
        </div>
      </div>
    </section>
  </main>

  <!-- Cart Floating Bar -->
  <div class="fixed bottom-24 left-4 right-4 z-50">
    <div class="bg-primary text-on-primary h-16 rounded-2xl flex items-center justify-between px-6 shadow-xl cursor-pointer hover:brightness-110 transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
          <span class="material-symbols-outlined">shopping_basket</span>
        </div>
        <div>
          <p class="font-bold text-label-md leading-none">0 Items</p>
          <p class="text-[10px] text-white/80">₹0 • Spice Village Order</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-bold uppercase tracking-widest text-sm">Place Order</span>
        <span class="material-symbols-outlined">arrow_forward</span>
      </div>
    </div>
  </div>

  <!-- Bottom Navigation -->
  <nav class="fixed bottom-0 w-full flex justify-around items-center h-20 pb-safe px-4 bg-surface/80 backdrop-blur-xl z-50 border-t border-outline-variant/30 shadow-[0_-4px_12px_rgba(0,0,0,0.04)]">
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/home">
      <span class="material-symbols-outlined">home</span>
      <span class="font-label-sm text-label-sm">Home</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/orders">
      <span class="material-symbols-outlined">receipt_long</span>
      <span class="font-label-sm text-label-sm">Orders</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/grocery">
      <span class="material-symbols-outlined">search</span>
      <span class="font-label-sm text-label-sm">Search</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary transition-all" href="/profile">
      <span class="material-symbols-outlined">person</span>
      <span class="font-label-sm text-label-sm">Account</span>
    </a>
  </nav>

  <script is:inline>
    // Veg/Non-veg filter toggling
    const btnAll = document.getElementById('btn-all');
    const btnVeg = document.getElementById('btn-veg');
    const btnNonVeg = document.getElementById('btn-nonveg');
    const items = document.querySelectorAll('.food-item');

    function applyFilter(type) {
      items.forEach(item => {
        if (type === 'all' || item.getAttribute('data-type') === type) {
          item.classList.remove('hidden');
          item.classList.add('flex');
        } else {
          item.classList.remove('flex');
          item.classList.add('hidden');
        }
      });
    }

    btnAll.addEventListener('click', () => {
      btnAll.className = "px-4 py-2 rounded-full border border-primary bg-primary-fixed/30 text-primary font-bold text-xs transition-all";
      btnVeg.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-tertiary font-bold text-xs flex items-center gap-1 transition-all";
      btnNonVeg.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-error font-bold text-xs flex items-center gap-1 transition-all";
      applyFilter('all');
    });

    btnVeg.addEventListener('click', () => {
      btnAll.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-on-surface font-bold text-xs transition-all";
      btnVeg.className = "px-4 py-2 rounded-full border border-tertiary bg-tertiary-fixed/30 text-tertiary font-bold text-xs flex items-center gap-1 transition-all";
      btnNonVeg.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-error font-bold text-xs flex items-center gap-1 transition-all";
      applyFilter('veg');
    });

    btnNonVeg.addEventListener('click', () => {
      btnAll.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-on-surface font-bold text-xs transition-all";
      btnVeg.className = "px-4 py-2 rounded-full border border-outline-variant bg-white text-tertiary font-bold text-xs flex items-center gap-1 transition-all";
      btnNonVeg.className = "px-4 py-2 rounded-full border border-error bg-error-container text-error font-bold text-xs flex items-center gap-1 transition-all";
      applyFilter('nonveg');
    });

    // Cart details
    let cart = [];
    let cartCount = 0;
    let cartTotal = 0;

    const cartBar = document.querySelector('.fixed.bottom-24');
    const cartTextCount = cartBar.querySelector('p.font-bold');
    const cartTextDetails = cartBar.querySelector('p.text-white\\/80');

    cartBar.classList.add('hidden');

    document.querySelectorAll('.food-item button').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const card = btn.closest('.food-item');
        const title = card.querySelector('h3').textContent.trim();
        const priceText = card.querySelector('.font-bold.text-on-surface').textContent.trim();
        const price = parseInt(priceText.replace(/[^\d]/g, ''));

        btn.textContent = 'Added';
        btn.classList.remove('bg-primary');
        btn.classList.add('bg-tertiary');
        btn.disabled = true;

        cart.push({ title, price });
        cartCount++;
        cartTotal += price;

        cartBar.classList.remove('hidden');
        cartTextCount.textContent = `${cartCount} Item${cartCount > 1 ? 's' : ''}`;
        cartTextDetails.textContent = `₹${cartTotal} • Spice Village Order`;
      });
    });

    cartBar.addEventListener('click', () => {
      if (cart.length > 0) {
        const order = {
          id: `FD-${Math.floor(1000 + Math.random() * 9000)}`,
          items: cart.map(item => item.title).join(', '),
          total: cartTotal,
          date: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
          status: 'Preparing'
        };

        const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
        orders.unshift(order);
        localStorage.setItem('bhusawal_orders', JSON.stringify(orders));
        localStorage.setItem('bhusawal_active_order', JSON.stringify(order));

        window.location.href = '/track_order';
      }
    });
  </script>

  <Switcher />
</body>
</html>
