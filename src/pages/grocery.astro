---
import fs from 'fs';
import path from 'path';
import Switcher from '../components/Switcher.astro';

// Read the database at build-time for static rendering
const jsonPath = path.join(process.cwd(), 'public/grocery_catalog.json');
let catalog = [];
try {
  catalog = JSON.parse(fs.readFileSync(jsonPath, 'utf8'));
} catch (err) {
  console.error("Failed to read grocery catalog at build time", err);
}

// Filter popular items per category for initial static load
const veggies = catalog.filter(i => i.Category === 'Fruits & Vegetables').slice(0, 4);
const dairy = catalog.filter(i => i.Category === 'Dairy' || i.Category === 'Bakery').slice(0, 4);
const staples = catalog.filter(i => i.Category === 'Rice, Atta & Flour' || i.Category === 'Spices & Masalas' || i.Category === 'Salt, Sugar & Jaggery').slice(0, 4);
const snacks = catalog.filter(i => i.Category === 'Snacks' || i.Category === 'Biscuits & Cookies' || i.Category === 'Chocolates' || i.Category === 'Noodles & Pasta').slice(0, 4);
const household = catalog.filter(i => i.Category === 'Home Cleaning' || i.Category === 'Laundry' || i.Category === 'Bathroom Cleaning').slice(0, 4);
const personal = catalog.filter(i => i.Category === 'Personal Care').slice(0, 4);
