                <img alt={p["Product Name"]} class="w-full h-full object-contain mix-blend-multiply group-hover:scale-105 transition-transform duration-300" 
                     src={p["Product Image URL"] || '/assets/d686bc969706f3bd6cf093f663be9579.jpg'} onerror="this.src='/assets/d686bc969706f3bd6cf093f663be9579.jpg';" />
                <div class="absolute top-2 left-2 bg-pink-600 text-white text-[7px] px-1.5 py-0.5 rounded font-extrabold uppercase tracking-wider">Care</div>
                <button class="absolute bottom-2 right-2 bg-white border border-[#ff3f6c] text-[#ff3f6c] px-3 py-1 rounded-lg text-[10px] font-extrabold shadow-md hover:bg-[#ff3f6c]/5 active:scale-95 transition-all duration-200 btn-add-static">ADD</button>
              </div>
              <div class="flex-grow flex flex-col justify-between">
                <div>
                  <div class="flex items-center flex-wrap gap-1">
                    <span class="bg-[#0c831f] text-white px-1.5 py-0.5 rounded text-[10px] font-extrabold selling-price">₹{p.MRP}</span>
                  </div>
                  <h3 class="text-[11px] font-extrabold text-neutral-800 line-clamp-2 h-7.5 mt-1.5 leading-snug">{p["Product Name"]}</h3>
                </div>
                <div class="mt-1">
                  <p class="text-[9px] text-neutral-500 font-bold">{p["Pack Size"] || '1 Unit'}</p>
                  <div class="flex items-center gap-0.5 text-[9px] text-neutral-500 font-extrabold mt-0.5">
                    <span class="text-[#0c831f]">★</span>
                    <span>4.7</span>
                    <span class="text-neutral-400 font-normal">({p.StockQuantity || '3.5k'})</span>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>

  <!-- Cart Floating Bar -->
  <div class="fixed bottom-24 left-4 right-4 z-50">
    <div class="bg-primary text-on-primary h-16 rounded-2xl flex items-center justify-between px-6 shadow-xl cursor-pointer hover:brightness-110 transition-all">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
          <span class="material-symbols-outlined" data-icon="shopping_basket">shopping_basket</span>
        </div>
        <div>
          <p class="font-bold text-label-md leading-none">0 Items</p>
          <p class="text-[10px] text-white/80">₹0 • Shivaji Nagar</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-bold uppercase tracking-widest text-sm">View Cart</span>
        <span class="material-symbols-outlined" data-icon="arrow_forward">arrow_forward</span>
      </div>
    </div>
  </div>

  <!-- BottomNavBar -->
  <nav class="fixed bottom-0 w-full flex justify-around items-center h-20 pb-safe px-4 bg-surface/80 dark:bg-inverse-surface/80 backdrop-blur-xl z-50 rounded-t-xl border-t border-outline-variant/30 shadow-[0_-4px_12px_rgba(0,0,0,0.04)]">
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all active:scale-90 duration-200" href="/home">
      <span class="material-symbols-outlined" data-icon="home">home</span>
      <span class="font-label-sm text-label-sm">Home</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all active:scale-90 duration-200" href="/orders">
      <span class="material-symbols-outlined" data-icon="receipt_long">receipt_long</span>
      <span class="font-label-sm text-label-sm">Orders</span>
    </a>
    <a class="flex flex-col items-center justify-center text-primary bg-primary-fixed/30 rounded-full px-4 py-1 active:scale-90 duration-200 transition-all" href="/grocery">
      <span class="material-symbols-outlined" data-icon="search" style="font-variation-settings: 'FILL' 1;">search</span>
      <span class="font-label-sm text-label-sm">Search</span>
    </a>
    <a class="flex flex-col items-center justify-center text-secondary hover:text-primary-container transition-all active:scale-90 duration-200" href="/profile">
      <span class="material-symbols-outlined" data-icon="person">person</span>
      <span class="font-label-sm text-label-sm">Account</span>
    </a>
  </nav>

  <script is:inline>
    // Smooth scroll and dynamic click behavior
    let fullCatalog = [];
    let cart = [];
    let cartCount = 0;
    let cartTotal = 0;

    const mainEl = document.querySelector('main');
    const originalMainHTML = mainEl.innerHTML;
    const cartBar = document.querySelector('.fixed.bottom-24');
    const cartTextCount = cartBar.querySelector('p.font-bold');
    const cartTextDetails = cartBar.querySelector('p.text-white\\/80');

    // Hide cart bar by default
    cartBar.classList.add('hidden');

    const categoryMappings = {
      'section-veggies': ['Fruits & Vegetables'],
      'section-dairy': ['Dairy', 'Bakery'],
      'section-staples': ['Rice, Atta & Flour', 'Dal & Pulses', 'Cooking Oil & Ghee', 'Spices & Masalas', 'Salt, Sugar & Jaggery'],
      'section-snacks': ['Snacks', 'Biscuits & Cookies', 'Chocolates', 'Noodles & Pasta'],
      'section-drinks': ['Beverages', 'Tea & Coffee'],
      'section-personal': ['Personal Care', 'OTC Medical Products', "Women's Hygiene", 'Sexual Wellness'],
      'section-household': ['Home Cleaning', 'Laundry', 'Bathroom Cleaning', 'Kitchen Cleaning', 'Kitchen Essentials', 'Disposable Products', 'Pooja Items']
    };

    // Load Indian Grocery Database JSON
    fetch('/grocery_catalog.json')
      .then(res => res.json())
      .then(data => {
        fullCatalog = data;
        console.log('Indian Grocery database loaded successfully: ' + fullCatalog.length + ' products.');
      })
      .catch(err => console.error('Failed to load database JSON', err));

    function bindStaticButtons() {
      document.querySelectorAll('main button.btn-add-static').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const parent = btn.parentElement;
          const card = btn.closest('.group');
          const title = card.querySelector('h3').textContent.trim();
          const priceText = card.querySelector('.selling-price').textContent.trim();
          const price = parseInt(priceText.replace(/[^\d]/g, ''));

          btn.textContent = 'Added';
          btn.classList.remove('bg-white', 'text-primary', 'border-primary/40', 'hover:bg-primary/5');
          btn.classList.add('bg-tertiary', 'text-white', 'border-tertiary');
          btn.disabled = true;

          cart.push({ title, price });
          cartCount++;
          cartTotal += price;

          cartBar.classList.remove('hidden');
          cartTextCount.textContent = cartCount + ' Item' + (cartCount > 1 ? 's' : '');
          cartTextDetails.textContent = '₹' + cartTotal + ' • Shivaji Nagar';
        });
      });
    }

    function bindScrollButtons() {
      document.querySelectorAll('[data-target]').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          if (fullCatalog.length > 0 && categoryMappings[targetId]) {
            const allowedCats = categoryMappings[targetId];
            const matches = fullCatalog.filter(item => allowedCats.includes(item.Category));
            const categoryLabel = btn.querySelector('span:last-child').textContent.trim();
            renderProductList(categoryLabel, matches.slice(0, 100));
            window.scrollTo({ top: 0, behavior: 'smooth' });
          } else {
            const targetEl = document.getElementById(targetId);
            if (targetEl) {
              targetEl.scrollIntoView({ behavior: 'smooth' });
            }
          }
        });
      });
    }

    function renderProductList(title, products) {
      const heading = '<div class="flex items-center justify-between mb-6">' +
        '<h2 class="font-headline-md text-headline-md text-on-surface">' + title + ' (' + products.length + ' Items)</h2>' +
        '<button id="btn-clear-filter" class="text-primary font-label-md text-label-md flex items-center gap-1">' +
          'Back to Home <span class="material-symbols-outlined text-sm">close</span>' +
        '</button>' +
      '</div>';

      let gridHTML = '<div class="grid grid-cols-2 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8 gap-3">';
      products.forEach(p => {
        const tag = p.Category === 'Fruits & Vegetables' ? 'Organic' : 'Bestseller';
        const tagColor = p.Category === 'Fruits & Vegetables' ? 'bg-emerald-600 text-white' : 'bg-[#ffc107] text-neutral-900';
        const price = p.MRP;
        const mrpHtml = '';
        const discountHtml = '';
        const ratingCount = p.StockQuantity || '3.5k';

        let iconName = 'shopping_bag';
        if (p.Category === 'Fruits & Vegetables') iconName = 'eco';
        else if (p.Category === 'Dairy' || p.Category === 'Bakery') iconName = 'water_drop';
        else if (p.Category === 'Rice, Atta & Flour' || p.Category === 'Spices & Masalas' || p.Category === 'Salt, Sugar & Jaggery') iconName = 'inventory_2';
        else if (p.Category === 'Snacks' || p.Category === 'Biscuits & Cookies' || p.Category === 'Chocolates' || p.Category === 'Noodles & Pasta') iconName = 'cookie';
        else if (p.Category === 'Home Cleaning' || p.Category === 'Laundry' || p.Category === 'Bathroom Cleaning') iconName = 'cleaning_services';
        else if (p.Category === 'Personal Care') iconName = 'sanitizer';

        gridHTML += '<div class="bg-white rounded-2xl p-2.5 shadow-[0_8px_16px_rgba(0,0,0,0.02)] flex flex-col group border border-neutral-100/80 hover:border-primary/20 hover:shadow-[0_8px_24px_rgba(0,0,0,0.05)] transition-all duration-300 relative">' +
          '<div class="w-full aspect-square rounded-xl bg-[#f8f9fa] mb-2.5 relative flex items-center justify-center p-2.5 overflow-hidden">' +
            '<div class="w-full h-full flex items-center justify-center bg-neutral-100/30 rounded-lg">' +
              '<span class="material-symbols-outlined text-2xl text-neutral-300 group-hover:scale-110 transition-transform duration-300" data-icon="' + iconName + '">' + iconName + '</span>' +
            '</div>' +
            '<div class="absolute top-2 left-2 ' + tagColor + ' text-[7px] px-1.5 py-0.5 rounded font-extrabold uppercase tracking-wider">' + tag + '</div>' +
            '<button class="absolute bottom-2 right-2 bg-white border border-[#ff3f6c] text-[#ff3f6c] px-3 py-1 rounded-lg text-[10px] font-extrabold shadow-md hover:bg-[#ff3f6c]/5 active:scale-95 transition-all duration-200 btn-add-dynamic">ADD</button>' +
          '</div>' +
          '<div class="flex-grow flex flex-col justify-between">' +
            '<div>' +
              '<div class="flex items-center flex-wrap gap-1">' +
                '<span class="bg-[#0c831f] text-white px-1.5 py-0.5 rounded text-[10px] font-extrabold selling-price">₹' + price + '</span>' +
                mrpHtml +
              '</div>' +
              discountHtml +
              '<h3 class="text-[11px] font-extrabold text-neutral-800 line-clamp-2 h-7.5 mt-1.5 leading-snug">' + p["Product Name"] + '</h3>' +
            '</div>' +
            '<div class="mt-1">' +
              '<p class="text-[9px] text-neutral-500 font-bold">' + (p["Pack Size"] || '1 Unit') + '</p>' +
              '<div class="flex items-center gap-0.5 text-[9px] text-neutral-500 font-extrabold mt-0.5">' +
                '<span class="text-[#0c831f]">★</span>' +
                '<span>4.7</span>' +
                '<span class="text-neutral-400 font-normal">(' + ratingCount + ')</span>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      });
      gridHTML += '</div>';

      mainEl.innerHTML = '<section class="pb-20">' + heading + gridHTML + '</section>';

      mainEl.querySelectorAll('.btn-add-dynamic').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const card = btn.closest('.group');
          const itemTitle = card.querySelector('h3').textContent.trim();
          const priceText = card.querySelector('.selling-price').textContent.trim();
          const itemPrice = parseInt(priceText.replace(/[^\d]/g, ''));

          cart.push({ title: itemTitle, price: itemPrice });
          cartCount++;
          cartTotal += itemPrice;

          btn.textContent = 'Added';
          btn.classList.remove('bg-white', 'text-primary', 'border-primary/40', 'hover:bg-primary/5');
          btn.classList.add('bg-tertiary', 'text-white', 'border-tertiary');
          btn.disabled = true;

          cartBar.classList.remove('hidden');
          cartTextCount.textContent = cartCount + ' Item' + (cartCount > 1 ? 's' : '');
          cartTextDetails.textContent = '₹' + cartTotal + ' • Shivaji Nagar';
        });
      });

      document.getElementById('btn-clear-filter').addEventListener('click', () => {
        restoreOriginalGrid();
      });
    }

    // Bind initial behaviors
    bindStaticButtons();
    bindScrollButtons();

    // Bind Search Input dynamic matches
    const searchInput = document.querySelector('input');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const query = e.target.value.trim().toLowerCase();
        if (query.length > 1) {
          const matches = fullCatalog.filter(item => {
            const nameMatch = (item["Product Name"] || '').toLowerCase().includes(query);
            const brandMatch = (item["Brand Name"] || '').toLowerCase().includes(query);
            const categoryMatch = (item.Category || '').toLowerCase().includes(query);
            return nameMatch || brandMatch || categoryMatch;
          });
          renderProductList('Search Results for "' + e.target.value + '"', matches.slice(0, 40));
        } else if (query.length === 0) {
          restoreOriginalGrid();
        }
      });
    }

    // Scroll shadow effect
    window.addEventListener('scroll', () => {
      const header = document.querySelector('header');
      if (header) {
        if (window.scrollY > 10) {
          header.classList.add('shadow-md');
        } else {
          header.classList.remove('shadow-md');
        }
      }
    });

    // Cart redirect
    cartBar.addEventListener('click', () => {
      if (cart.length > 0) {
        const order = {
          id: 'BHU-' + Math.floor(1000 + Math.random() * 9000),
          items: cart.map(item => item.title).join(', '),
          total: cartTotal,
          date: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
          status: 'Preparing'
        };

        const orders = JSON.parse(localStorage.getItem('bhusawal_orders') || '[]');
        orders.unshift(order);
        localStorage.setItem('bhusawal_orders', JSON.stringify(orders));
        localStorage.setItem('bhusawal_active_order', JSON.stringify(order));

        window.location.href = '/track_order';
      }
    });
  </script>
  <Switcher />
</body>
</html>